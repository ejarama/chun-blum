rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }

    function rol() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    function esSoloActualizacionDeStock() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['stockDisponible', 'estado', 'ultimaActualizacion']);
    }

    // Usuarios
    match /usuarios/{uid} {
      allow read:  if autenticado() && request.auth.uid == uid;
      allow read, write: if autenticado() && rol() == 'admin';
    }

    // Productos
    match /productos/{productoId} {
      allow read: if autenticado();
      allow write: if autenticado() && rol() in ['admin', 'operaria'];
      allow update: if autenticado() && (
        rol() in ['admin', 'operaria'] ||
        (rol() == 'distribuidor' && esSoloActualizacionDeStock())
      );
    }

    // Pedidos
    match /pedidos/{pedidoId} {
      allow read: if autenticado() && (
        resource.data.distribuidorId == request.auth.uid ||
        rol() in ['admin', 'vendedor']
      );
      allow create: if autenticado() &&
        request.resource.data.distribuidorId == request.auth.uid;
      allow update: if autenticado() && rol() in ['admin', 'vendedor'];
      allow delete: if false;
    }

    // Lotes de produccion (coleccion real en el codigo: lotes_produccion)
    // create sin get() para evitar el ciclo de evaluacion en reglas
    match /lotes_produccion/{loteId} {
      allow read:           if autenticado();
      allow create:         if autenticado();
      allow update, delete: if autenticado() && rol() == 'admin';
    }
  }
}
